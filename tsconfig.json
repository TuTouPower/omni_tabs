{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["wxt/browser"]
  },
  "include": ["lib/**/*.ts", "entrypoints/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".output"]
}
