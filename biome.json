{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "files": {
        "includes": [
            "**",
            "!.output",
            "!.wxt",
            "!node_modules",
            "!coverage",
            "!package-lock.json",
            "!.superpowers"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none"
        }
    }
}
